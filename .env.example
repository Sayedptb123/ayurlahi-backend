# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=yourpassword
DB_NAME=ayurlahi

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── AWS S3 (file uploads) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=medilink-uploads

# ─── Razorpay (payments) ──────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@ayurlahi.com

# ─── Redis (BullMQ queues) ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Frontend URL (CORS) ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173
